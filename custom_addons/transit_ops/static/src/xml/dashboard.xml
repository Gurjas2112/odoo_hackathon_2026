<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="transit_ops.Dashboard">
        <div class="to_dashboard">
            <!-- Header -->
            <div class="to_header d-flex justify-content-between align-items-center flex-wrap mb-4">
                <div>
                    <h1>
                        <i class="fa fa-tachometer me-2" style="color: var(--to-emerald);"/>
                        TransitOps Dashboard
                    </h1>
                    <p>Real-time fleet operations overview</p>
                </div>
                <button class="btn btn-outline-secondary" t-on-click="onRefresh">
                    <i class="fa fa-refresh me-1"/> Refresh
                </button>
            </div>

            <!-- Loading -->
            <t t-if="state.loading">
                <div class="text-center py-5">
                    <i class="fa fa-spinner fa-spin fa-3x text-muted"/>
                    <p class="mt-3 text-muted">Loading dashboard...</p>
                </div>
            </t>

            <t t-if="!state.loading">
                <!-- KPI Cards Grid -->
                <div class="to_kpi_grid">
                    <!-- Active Vehicles -->
                    <div class="to_kpi_card emerald" t-on-click="onViewVehicles" style="cursor:pointer">
                        <div class="to_kpi_icon"><i class="fa fa-truck"/></div>
                        <div class="to_kpi_value" t-esc="state.kpis.activeVehicles"/>
                        <div class="to_kpi_label">Active Vehicles</div>
                    </div>

                    <!-- Available -->
                    <div class="to_kpi_card blue" t-on-click="onViewVehicles" style="cursor:pointer">
                        <div class="to_kpi_icon"><i class="fa fa-check-circle"/></div>
                        <div class="to_kpi_value" t-esc="state.kpis.availableVehicles"/>
                        <div class="to_kpi_label">Available Vehicles</div>
                    </div>

                    <!-- In Maintenance -->
                    <div class="to_kpi_card amber" t-on-click="onViewMaintenance" style="cursor:pointer">
                        <div class="to_kpi_icon"><i class="fa fa-wrench"/></div>
                        <div class="to_kpi_value" t-esc="state.kpis.inMaintenance"/>
                        <div class="to_kpi_label">In Maintenance</div>
                    </div>

                    <!-- Active Trips -->
                    <div class="to_kpi_card purple" t-on-click="onViewTrips" style="cursor:pointer">
                        <div class="to_kpi_icon"><i class="fa fa-road"/></div>
                        <div class="to_kpi_value" t-esc="state.kpis.activeTrips"/>
                        <div class="to_kpi_label">Active Trips</div>
                    </div>

                    <!-- Pending Trips -->
                    <div class="to_kpi_card navy" t-on-click="onViewTrips" style="cursor:pointer">
                        <div class="to_kpi_icon"><i class="fa fa-clock-o"/></div>
                        <div class="to_kpi_value" t-esc="state.kpis.pendingTrips"/>
                        <div class="to_kpi_label">Pending Trips</div>
                    </div>

                    <!-- Drivers On Duty -->
                    <div class="to_kpi_card emerald" t-on-click="onViewDrivers" style="cursor:pointer">
                        <div class="to_kpi_icon"><i class="fa fa-user"/></div>
                        <div class="to_kpi_value" t-esc="state.kpis.driversOnDuty"/>
                        <div class="to_kpi_label">Drivers On Duty</div>
                    </div>

                    <!-- Fleet Utilisation -->
                    <div class="to_kpi_card blue">
                        <div class="to_kpi_icon"><i class="fa fa-pie-chart"/></div>
                        <div class="to_kpi_value"><t t-esc="state.kpis.utilisation"/>%</div>
                        <div class="to_kpi_label">Fleet Utilisation</div>
                    </div>

                    <!-- License Alerts -->
                    <div class="to_kpi_card red" t-on-click="onViewDrivers" style="cursor:pointer">
                        <div class="to_kpi_icon"><i class="fa fa-exclamation-triangle"/></div>
                        <div class="to_kpi_value" t-esc="state.kpis.expiringLicenses"/>
                        <div class="to_kpi_label">License Alerts</div>
                    </div>
                </div>

                <!-- Quick Action Buttons -->
                <div class="to_quick_actions">
                    <button class="btn btn-primary" t-on-click="onNewTrip">
                        <i class="fa fa-plus"/> New Trip
                    </button>
                    <button class="btn btn-outline-primary" t-on-click="onViewTrips">
                        <i class="fa fa-list"/> All Trips
                    </button>
                    <button class="btn btn-outline-secondary" t-on-click="onViewVehicles">
                        <i class="fa fa-truck"/> Fleet
                    </button>
                    <button class="btn btn-outline-secondary" t-on-click="onViewDrivers">
                        <i class="fa fa-users"/> Drivers
                    </button>
                    <button class="btn btn-outline-secondary" t-on-click="onViewMaintenance">
                        <i class="fa fa-wrench"/> Maintenance
                    </button>
                    <button class="btn btn-outline-secondary" t-on-click="onViewFuelLogs">
                        <i class="fa fa-tint"/> Fuel Logs
                    </button>
                </div>

                <!-- Summary Stats Row -->
                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm" style="border-radius: var(--to-radius);">
                            <div class="card-body">
                                <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.78rem; letter-spacing:0.5px;">
                                    <i class="fa fa-check-circle text-success me-1"/> Completed Trips
                                </h6>
                                <h2 class="fw-bold mb-0" style="color: var(--to-navy);" t-esc="state.kpis.completedTrips"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm" style="border-radius: var(--to-radius);">
                            <div class="card-body">
                                <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.78rem; letter-spacing:0.5px;">
                                    <i class="fa fa-users text-primary me-1"/> Total Drivers
                                </h6>
                                <h2 class="fw-bold mb-0" style="color: var(--to-navy);" t-esc="state.kpis.totalDrivers"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm" style="border-radius: var(--to-radius);">
                            <div class="card-body">
                                <h6 class="text-muted fw-bold text-uppercase" style="font-size:0.78rem; letter-spacing:0.5px;">
                                    <i class="fa fa-inr text-warning me-1"/> Total Fuel Cost
                                </h6>
                                <h2 class="fw-bold mb-0" style="color: var(--to-navy);">₹<t t-esc="state.kpis.totalFuelCost"/></h2>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>

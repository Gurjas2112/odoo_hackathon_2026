<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ============================================ -->
        <!-- LICENSE EXPIRY CRON JOB — Bonus Feature      -->
        <!-- Runs daily, flags expiring/expired licenses  -->
        <!-- ============================================ -->
        <record id="cron_license_expiry_check" model="ir.cron">
            <field name="name">TransitOps: License Expiry Check</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_license_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Cron to check driver license expiry daily -->
        <record id="cron_check_driver_license_expiry" model="ir.cron">
            <field name="name">Driver License Expiry Checker</field>
            <field name="model_id" ref="transit_ops.model_transit_driver"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_driver_license_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron to check vehicle odometer and auto-trigger maintenance daily -->
        <record id="cron_check_vehicle_odometer" model="ir.cron">
            <field name="name">Vehicle Odometer Maintenance Checker</field>
            <field name="model_id" ref="transit_ops.model_transit_vehicle"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_vehicle_odometer()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ============================================ -->
        <!-- LICENSE EXPIRY CRON JOB — Bonus Feature      -->
        <!-- Runs daily, flags expiring/expired licenses  -->
        <!-- ============================================ -->
        <record id="cron_license_expiry_check" model="ir.cron">
            <field name="name">TransitOps: License Expiry Check</field>
            <field name="model_id" ref="model_transit_driver"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_license_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>

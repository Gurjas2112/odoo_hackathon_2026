<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- EXPENSE FORM -->
    <record id="view_transit_expense_form" model="ir.ui.view">
        <field name="name">transit.expense.form</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <header>
                    <button name="action_confirm" string="Confirm"
                        type="object" class="btn-primary"
                        invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Reference">
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="trip_id" options="{'no_create': True}"/>
                            <field name="date"/>
                        </group>
                        <group string="Cost Breakdown">
                            <field name="fuel_cost"/>
                            <field name="toll_cost"/>
                            <field name="other_cost"/>
                            <field name="maintenance_cost" readonly="1"
                                help="Auto-linked from closed maintenance records"/>
                            <field name="total" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- EXPENSE LIST -->
    <record id="view_transit_expense_list" model="ir.ui.view">
        <field name="name">transit.expense.list</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <list string="Expenses">
                <field name="trip_id"/>
                <field name="vehicle_id"/>
                <field name="fuel_cost" sum="Fuel"/>
                <field name="toll_cost" sum="Tolls"/>
                <field name="other_cost" sum="Other"/>
                <field name="maintenance_cost" sum="Maintenance"/>
                <field name="total" sum="Grand Total"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <!-- EXPENSE SEARCH -->
    <record id="view_transit_expense_search" model="ir.ui.view">
        <field name="name">transit.expense.search</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <search string="Search Expenses">
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <filter string="Vehicle" name="group_vehicle"
                        context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_transit_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">transit.expense</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first expense
            </p>
            <p>Expenses are auto-created on trip completion. Add additional expenses here.</p>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FUEL LOG FORM -->
    <record id="view_transit_fuel_form" model="ir.ui.view">
        <field name="name">transit.fuel.log.form</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <form string="Fuel Log">
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="trip_id" options="{'no_create': True}"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="liters"/>
                            <field name="cost"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- FUEL LOG LIST -->
    <record id="view_transit_fuel_list" model="ir.ui.view">
        <field name="name">transit.fuel.log.list</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <list string="Fuel Logs" editable="bottom">
                <field name="vehicle_id"/>
                <field name="trip_id" optional="show"/>
                <field name="date"/>
                <field name="liters" sum="Total Liters"/>
                <field name="cost" sum="Total Fuel Cost"/>
            </list>
        </field>
    </record>

    <!-- FUEL LOG SEARCH -->
    <record id="view_transit_fuel_search" model="ir.ui.view">
        <field name="name">transit.fuel.log.search</field>
        <field name="model">transit.fuel.log</field>
        <field name="arch" type="xml">
            <search string="Search Fuel Logs">
                <field name="vehicle_id"/>
                <field name="trip_id"/>
                <filter string="Vehicle" name="group_vehicle"
                        context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Month" name="group_month"
                        context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_transit_fuel" model="ir.actions.act_window">
        <field name="name">Fuel Logs</field>
        <field name="res_model">transit.fuel.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_fuel_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your first fuel entry
            </p>
            <p>Fuel logs are auto-created when a trip is completed. You can also add them manually.</p>
        </field>
    </record>
</odoo>

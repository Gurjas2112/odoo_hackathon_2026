<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- MAINTENANCE FORM VIEW                         -->
    <!-- ============================================ -->
    <record id="view_transit_maintenance_form" model="ir.ui.view">
        <field name="name">transit.maintenance.form</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <header>
                    <button name="action_close" string="Close Maintenance"
                        type="object" class="btn-primary"
                        invisible="state != 'active'"
                        confirm="Close this maintenance record? Vehicle will return to Available (unless Retired)."/>
                    <button name="action_reopen" string="Reopen"
                        type="object"
                        invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="active,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Service Details">
                            <field name="vehicle_id"
                                readonly="state == 'closed'"
                                options="{'no_create': True}"/>
                            <field name="service_type"
                                placeholder="e.g. Oil Change, Tyre Replace"/>
                            <field name="cost"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional maintenance notes..."/>
                    </group>
                    <div class="alert alert-warning" role="alert"
                         invisible="state != 'active'">
                        <strong>⚠ Note:</strong> This vehicle is now <b>In Shop</b>
                        and has been removed from the dispatch pool.
                        Close this record to return it to Available.
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- MAINTENANCE LIST VIEW                         -->
    <!-- ============================================ -->
    <record id="view_transit_maintenance_list" model="ir.ui.view">
        <field name="name">transit.maintenance.list</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance Log">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="cost" sum="Total Cost"/>
                <field name="date"/>
                <field name="state" widget="badge"
                    decoration-warning="state == 'active'"
                    decoration-success="state == 'closed'"/>
            </list>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- MAINTENANCE SEARCH VIEW                       -->
    <!-- ============================================ -->
    <record id="view_transit_maintenance_search" model="ir.ui.view">
        <field name="name">transit.maintenance.search</field>
        <field name="model">transit.maintenance</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance">
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <separator/>
                <filter string="Active" name="filter_active"
                    domain="[('state', '=', 'active')]"/>
                <filter string="Closed" name="filter_closed"
                    domain="[('state', '=', 'closed')]"/>
                <filter string="Vehicle" name="group_vehicle"
                        context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_transit_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transit.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transit_maintenance_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log your first service record
            </p>
            <p>Creating an active maintenance record will automatically set the vehicle to In Shop.</p>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- RBAC GROUPS (PS §2 + §3.1)                    -->
    <!-- Odoo 19.0: res.groups no longer has           -->
    <!-- category_id — groups are standalone            -->
    <!-- ============================================ -->

    <!-- Fleet Manager: Fleet, Drivers, Maintenance, Analytics -->
    <record id="group_fleet_manager" model="res.groups">
        <field name="name">TransitOps / Fleet Manager</field>
    </record>

    <!-- Dispatcher: Trips (full), Fleet (view only) -->
    <record id="group_dispatcher" model="res.groups">
        <field name="name">TransitOps / Dispatcher</field>
    </record>

    <!-- Safety Officer: Drivers (full), Trips (view only) -->
    <record id="group_safety_officer" model="res.groups">
        <field name="name">TransitOps / Safety Officer</field>
    </record>

    <!-- Financial Analyst: Fuel/Expenses (full), Analytics, Fleet (view only) -->
    <record id="group_financial_analyst" model="res.groups">
        <field name="name">TransitOps / Financial Analyst</field>
    </record>
</odoo>

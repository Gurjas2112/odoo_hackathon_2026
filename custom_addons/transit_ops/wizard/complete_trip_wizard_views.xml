<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_transit_complete_trip_wizard_form" model="ir.ui.view">
        <field name="name">transit.complete.trip.wizard.form</field>
        <field name="model">transit.complete.trip.wizard</field>
        <field name="arch" type="xml">
            <form string="Complete Trip Details">
                <group>
                    <group>
                        <field name="trip_id" readonly="1"/>
                        <field name="vehicle_name"/>
                        <field name="driver_name"/>
                        <field name="current_odometer"/>
                    </group>
                    <group>
                        <field name="final_odometer" placeholder="Must be >= current odometer"/>
                        <field name="fuel_consumed" placeholder="Liters consumed"/>
                        <field name="fuel_cost" placeholder="Fuel cost in ₹"/>
                        <field name="toll_cost" placeholder="Tolls, parking, etc."/>
                    </group>
                </group>
                <footer>
                    <button name="action_complete" string="Complete Trip" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_transit_complete_trip_wizard" model="ir.actions.act_window">
        <field name="name">Complete Trip</field>
        <field name="res_model">transit.complete.trip.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Module Category -->
    <record id="module_category_hackathon" model="ir.module.category">
        <field name="name">Hackathon</field>
        <field name="sequence">100</field>
    </record>

    <!-- User Group -->
    <record id="group_hackathon_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_hackathon"/>
    </record>

    <!-- Manager Group (inherits User) -->
    <record id="group_hackathon_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_hackathon"/>
        <field name="implied_ids" eval="[(4, ref('group_hackathon_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- FORM VIEW                                     -->
    <!-- ============================================ -->
    <record id="view_hackathon_record_form" model="ir.ui.view">
        <field name="name">hackathon.record.form</field>
        <field name="model">hackathon.record</field>
        <field name="arch" type="xml">
            <form string="Record">
                <header>
                    <button name="action_confirm" string="Confirm"
                        type="object" class="btn-primary"
                        invisible="state != 'draft'"/>
                    <button name="action_start" string="Start"
                        type="object" class="btn-primary"
                        invisible="state != 'confirmed'"/>
                    <button name="action_done" string="Mark Done"
                        type="object" class="btn-success"
                        invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel"
                        type="object" class="btn-secondary"
                        invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                        type="object"
                        invisible="state not in ('cancelled',)"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>

                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_lines" type="object"
                            class="oe_stat_button" icon="fa-list">
                            <field name="total_lines" widget="statinfo"
                                string="Lines"/>
                        </button>
                    </div>

                    <!-- Title -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Enter name..."/>
                        </h1>
                    </div>

                    <!-- Main Fields -->
                    <group>
                        <group string="General Information">
                            <field name="partner_id"/>
                            <field name="user_id"
                                widget="many2one_avatar_user"/>
                            <field name="date"/>
                        </group>
                        <group string="Details">
                            <field name="amount"/>
                            <field name="total_amount"/>
                            <field name="priority" widget="priority"/>
                            <field name="company_id"
                                groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <!-- Tabs -->
                    <notebook>
                        <page string="Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal" sum="Total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Additional Info" name="info">
                            <group>
                                <field name="tag_ids" widget="many2many_tags"
                                    options="{'color_field': 'color'}"/>
                            </group>
                            <separator string="Notes"/>
                            <field name="description"
                                placeholder="Add notes here..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- LIST VIEW                                     -->
    <!-- ============================================ -->
    <record id="view_hackathon_record_list" model="ir.ui.view">
        <field name="name">hackathon.record.list</field>
        <field name="model">hackathon.record</field>
        <field name="arch" type="xml">
            <list string="Records"
                  decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'draft'"
                  multi_edit="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="amount" sum="Total"/>
                <field name="total_amount" sum="Grand Total"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="priority" widget="priority" optional="show"/>
                <field name="state"
                    widget="badge"
                    decoration-success="state == 'done'"
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'in_progress'"
                    decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- KANBAN VIEW                                   -->
    <!-- ============================================ -->
    <record id="view_hackathon_record_kanban" model="ir.ui.view">
        <field name="name">hackathon.record.kanban</field>
        <field name="model">hackathon.record</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    class="o_kanban_small_column"
                    quick_create="false">
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="priority"/>
                <field name="user_id"/>
                <field name="color"/>
                <progressbar field="state"
                    colors='{"draft": "secondary", "confirmed": "info",
                             "in_progress": "warning", "done": "success",
                             "cancelled": "danger"}'/>
                <templates>
                    <t t-name="kanban-card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong><field name="name"/></strong>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="partner_id"/></div>
                                <div class="mt-1">
                                    <strong>Amount: </strong>
                                    <field name="amount"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="date"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id"
                                        widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- SEARCH VIEW                                   -->
    <!-- ============================================ -->
    <record id="view_hackathon_record_search" model="ir.ui.view">
        <field name="name">hackathon.record.search</field>
        <field name="model">hackathon.record</field>
        <field name="arch" type="xml">
            <search string="Search Records">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter string="My Records" name="my_records"
                    domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                    domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="filter_confirmed"
                    domain="[('state', '=', 'confirmed')]"/>
                <filter string="In Progress" name="filter_in_progress"
                    domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="filter_done"
                    domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Archived" name="archived"
                    domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
                    <filter string="Customer" name="group_partner"
                        context="{'group_by': 'partner_id'}"/>
                    <filter string="Responsible" name="group_user"
                        context="{'group_by': 'user_id'}"/>
                    <filter string="Date" name="group_date"
                        context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- GRAPH VIEW                                    -->
    <!-- ============================================ -->
    <record id="view_hackathon_record_graph" model="ir.ui.view">
        <field name="name">hackathon.record.graph</field>
        <field name="model">hackathon.record</field>
        <field name="arch" type="xml">
            <graph string="Analysis" type="bar">
                <field name="state" type="row"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- PIVOT VIEW                                    -->
    <!-- ============================================ -->
    <record id="view_hackathon_record_pivot" model="ir.ui.view">
        <field name="name">hackathon.record.pivot</field>
        <field name="model">hackathon.record</field>
        <field name="arch" type="xml">
            <pivot string="Analysis">
                <field name="state" type="row"/>
                <field name="user_id" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- CALENDAR VIEW                                 -->
    <!-- ============================================ -->
    <record id="view_hackathon_record_calendar" model="ir.ui.view">
        <field name="name">hackathon.record.calendar</field>
        <field name="model">hackathon.record</field>
        <field name="arch" type="xml">
            <calendar string="Calendar" date_start="date"
                      color="user_id" mode="month"
                      quick_create="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>
</odoo>

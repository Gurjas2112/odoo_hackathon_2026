            raise ValidationError(
                f"Cargo weight {trip.cargo_weight} kg exceeds "
                f"{trip.vehicle_id.name} capacity of {trip.vehicle_id.max_load_capacity} kg. "
                f"Over by {trip.cargo_weight - trip.vehicle_id.max_load_capacity} kg."
            )

**Business Rule Methods ‚Äî THE CRITICAL PART:**

```python
def action_dispatch(self):
    """PS Rule 5,6: Validate + set both to On Trip"""
    for trip in self:
        # Rule 5: Cargo ‚â§ Capacity
        if trip.cargo_weight > trip.vehicle_id.max_load_capacity:
            raise UserError(f"Cargo {trip.cargo_weight} kg exceeds "
                          f"{trip.vehicle_id.name} capacity {trip.vehicle_id.max_load_capacity} kg")
        # Rule 3: License check
        if trip.driver_id.license_expiry < fields.Date.today():
            raise UserError(f"Driver {trip.driver_id.name}'s license expired on {trip.driver_id.license_expiry}")
        if trip.driver_id.status == 'suspended':
            raise UserError(f"Driver {trip.driver_id.name} is Suspended")
        # Rule 4: Already on trip
        if trip.vehicle_id.status != 'available':
            raise UserError(f"Vehicle {trip.vehicle_id.name} is {trip.vehicle_id.status}")
        if trip.driver_id.status != 'available':
            raise UserError(f"Driver {trip.driver_id.name} is {trip.driver_id.status}")
        # Rule 6: Dispatch ‚Üí both On Trip
        trip.state = 'dispatched'
        trip.vehicle_id.status = 'on_trip'
        trip.driver_id.status = 'on_trip'

def action_complete(self):
    """PS Rule 7: Complete ‚Üí both Available, update odometer"""
    for trip in self:
        trip.state = 'completed'
        trip.vehicle_id.status = 'available'
        trip.driver_id.status = 'available'
        if trip.final_odometer:
            trip.vehicle_id.odometer = trip.final_odometer
        # Auto-create fuel log
        if trip.fuel_consumed:
            self.env['transit.fuel.log'].create({
                'vehicle_id': trip.vehicle_id.id,
                'trip_id': trip.id,
                'date': fields.Date.today(),
                'liters': trip.fuel_consumed,
                'cost': trip.fuel_cost,
            })

def action_cancel(self):
    """PS Rule 8: Cancel ‚Üí both Available"""
    for trip in self:
        if trip.state == 'dispatched':
            trip.vehicle_id.status = 'available'
            trip.driver_id.status = 'available'
        trip.state = 'cancelled'
```

**Constraints:**
```python
@api.constrains('cargo_weight', 'vehicle_id')
def _check_cargo_capacity(self):
    for trip in self:

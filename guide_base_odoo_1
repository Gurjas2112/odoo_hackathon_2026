.\venv\Scripts\python.exe odoo-src\odoo-bin -c odoo.conf -d hackathon -i your_module --dev=all

# Update module after changes
.\venv\Scripts\python.exe odoo-src\odoo-bin -c odoo.conf -d hackathon -u your_module --dev=all

# Test install on fresh database
